{
    "manifest_version": 3,
    "name": "Checkpoint Extension",
    "version": "1.0.0",
    "action": {
        "default_title": "Checkpoint",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "service_worker.js"
    },
    "permissions": [
        "tabs",
        "alarms",
        "storage",
        "notifications",
        "activeTab"
    ],
    "host_permissions": [
        "http://localhost:6969/*",
        "<all_urls>"
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}